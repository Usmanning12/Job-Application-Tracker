@model WebApplication1.Models.Application

@{
    ViewData["Title"] = "Application Details";
}

<h2>Application Details</h2>

<div class="card p-3">
    <p><strong>Company:</strong> @Model.Company</p>
    <p><strong>Role:</strong> @Model.Position</p>
    <p><strong>Status:</strong> @Model.Status</p>
    <p><strong>Date Applied:</strong> @Model.AppliedDate.ToString("MM/dd/yyyy")</p>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning mt-3">Edit</a>
<a asp-action="Index" class="btn btn-secondary mt-3">Back</a>