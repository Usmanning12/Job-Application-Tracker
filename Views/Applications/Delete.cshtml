@model WebApplication1.Models.Application

@{
    ViewData["Title"] = "Delete Application";
}

<h2>Delete Application</h2>

<h4>Are you sure you want to delete this?</h4>

<div class="card p-3">
    <p><strong>Company:</strong> @Model.Company</p>
    <p><strong>Role:</strong> @Model.Position</p>
    <p><strong>Status:</strong> @Model.Status</p>
    <p><strong>Date Applied:</strong> @Model.AppliedDate.ToString("MM/dd/yyyy")</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger mt-3">Delete</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancel</a>
</form>