@{
    ViewData["Title"] = "Privacy Policy";
}

<h1>Privacy Policy</h1>

<p>
    This Job Tracker application imports job-related information from email accounts and stores only relevant application details.
</p>

<h3>What We Store</h3>
<ul>
    <li>Company Name</li>
    <li>Job Position</li>
    <li>Application Status</li>
    <li>Application Date</li>
</ul>

<h3>What We Do NOT Store</h3>
<ul>
    <li>Full email content</li>
    <li>Email attachments</li>
    <li>Personal message data unrelated to job applications</li>
</ul>

<h3>Data Usage</h3>
<p>
    This application is for educational purposes only. No data is shared with third parties or external services.
</p>

<h3>Security Note</h3>
<p>
    Email data is processed locally and only relevant job application details are saved into the database.
</p>